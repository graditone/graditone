#!/bin/sh
# Pre-push hook: fast checks (Rust tests, TS build, unit tests, E2E with timeout).
# E2E: killed after 3 min. Zero failures + timeout → CI handles the rest.
# Any failure in the captured output → push is blocked.

echo "🚀 Running pre-push validation..."

# Only run on pushes to main or feature branches
current_branch=$(git symbolic-ref --short HEAD)

if [ "$current_branch" = "main" ] || echo "$current_branch" | grep -qE '^[0-9]+-'; then
  echo "📦 Running full build check for branch: $current_branch"
  
  # Run Rust tests
  echo "  - Running Rust tests..."
  rust_output=$(cd backend && cargo test 2>&1)
  rust_exit=$?
  if [ $rust_exit -ne 0 ]; then
    echo ""
    echo "❌ Rust tests failed!"
    echo "$rust_output"
    echo ""
    echo "Tip: Fix errors or use 'git push --no-verify' to skip this check."
    exit 1
  fi
  # Summarise all test binaries: sum up passed/failed counts across all "test result:" lines
  passed=$(echo "$rust_output" | grep -E "^test result" | grep -oE "[0-9]+ passed" | awk -F' ' '{s+=$1} END {print s+0}')
  failed=$(echo "$rust_output" | grep -E "^test result" | grep -oE "[0-9]+ failed" | awk -F' ' '{s+=$1} END {print s+0}')
  echo "  test result: ok. $passed passed; $failed failed (across all modules)"

  cd frontend
  
  # Run full TypeScript build with production base path (catches sub-path issues)
  echo "  - Type checking and building..."
  if ! VITE_BASE=/musicore/ npm run build > /dev/null 2>&1; then
    echo ""
    echo "❌ Build failed! TypeScript errors detected."
    echo "Run 'cd frontend && npm run build' to see details."
    echo ""
    echo "Tip: Fix errors or use 'git push --no-verify' to skip this check."
    exit 1
  fi
  
  # Run tests
  echo "  - Running tests..."
  if ! npm test -- --run > /dev/null 2>&1; then
    echo ""
    echo "⚠️  Some tests failed. Review test output:"
    echo "Run 'cd frontend && npm test' to see details."
    echo ""
    echo "Tip: Use 'git push --no-verify' to skip if tests are expected to fail."
    exit 1
  fi

  # Run E2E tests with a 3-minute hard limit.
  # Correct tests finish in < 2 min. Hanging past 3 min means a test is timing
  # out due to a broken selector or missing element -- those show up as failures
  # in the captured output. If we hit the limit with zero failures recorded,
  # the suite was passing cleanly and CI will finish the run.
  echo "  - Running E2E tests (3 min limit)..."
  lsof -i :4173 -t 2>/dev/null | xargs kill -9 2>/dev/null || true
  timeout 180 npx playwright test --config playwright.config.prod.ts --reporter=list > /tmp/e2e-prepush.log 2>&1
  e2e_exit=$?

  e2e_passed=$(grep -c ' ✓ ' /tmp/e2e-prepush.log 2>/dev/null || echo 0)
  e2e_failed=$(grep -cE '^\s+[0-9]+\) \[' /tmp/e2e-prepush.log 2>/dev/null || echo 0)

  if [ "$e2e_exit" -eq 124 ]; then
    # Killed by the 3-min timeout
    if [ "$e2e_failed" -gt 0 ]; then
      echo ""
      echo "❌ E2E timed out with $e2e_failed failure(s) already detected ($e2e_passed passed):"
      tail -50 /tmp/e2e-prepush.log
      echo ""
      echo "Run 'cd frontend && npm run e2e' to reproduce locally."
      exit 1
    else
      echo "  ⏱  E2E hit 3-min limit — $e2e_passed passed, 0 failures. CI will finish the run."
    fi
  elif [ "$e2e_exit" -ne 0 ]; then
    echo ""
    echo "❌ E2E tests failed ($e2e_passed passed, $e2e_failed failed):"
    tail -50 /tmp/e2e-prepush.log
    echo ""
    echo "Run 'cd frontend && npm run e2e' to reproduce locally."
    exit 1
  else
    echo "  E2E: $e2e_passed tests passed"
  fi

  cd ..
  
  echo "✅ Build and tests passed"
else
  echo "ℹ️  Skipping validation for branch: $current_branch"
fi

echo "✅ Pre-push validation passed"
exit 0
