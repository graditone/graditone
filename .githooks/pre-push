#!/bin/sh
# Pre-push hook: fast checks (Rust tests, TS build, unit tests, E2E with 3-min limit).
# E2E: killed after 3 min. Zero failures + killed = CI covers the rest.
# Any failure in captured output blocks the push.

echo "🚀 Running pre-push validation..."

# Only run on pushes to main or feature branches
current_branch=$(git symbolic-ref --short HEAD)

if [ "$current_branch" = "main" ] || echo "$current_branch" | grep -qE '^[0-9]+-'; then
  echo "📦 Running full build check for branch: $current_branch"
  
  # Run Rust tests
  echo "  - Running Rust tests..."
  rust_output=$(cd backend && cargo test 2>&1)
  rust_exit=$?
  if [ $rust_exit -ne 0 ]; then
    echo ""
    echo "❌ Rust tests failed!"
    echo "$rust_output"
    echo ""
    echo "Tip: Fix errors or use 'git push --no-verify' to skip this check."
    exit 1
  fi
  # Summarise all test binaries: sum up passed/failed counts across all "test result:" lines
  passed=$(echo "$rust_output" | grep -E "^test result" | grep -oE "[0-9]+ passed" | awk -F' ' '{s+=$1} END {print s+0}')
  failed=$(echo "$rust_output" | grep -E "^test result" | grep -oE "[0-9]+ failed" | awk -F' ' '{s+=$1} END {print s+0}')
  echo "  test result: ok. $passed passed; $failed failed (across all modules)"

  cd frontend
  
  # Run full TypeScript build with production base path (catches sub-path issues)
  echo "  - Type checking and building..."
  if ! VITE_BASE=/musicore/ npm run build > /dev/null 2>&1; then
    echo ""
    echo "❌ Build failed! TypeScript errors detected."
    echo "Run 'cd frontend && npm run build' to see details."
    echo ""
    echo "Tip: Fix errors or use 'git push --no-verify' to skip this check."
    exit 1
  fi
  
  # Run tests (exclude tests/performance — timing-sensitive tests are flaky
  # under developer machine load; they pass in isolation and run cleanly in CI)
  echo "  - Running tests..."
  if ! npm test -- --run --exclude 'tests/performance/**' > /dev/null 2>&1; then
    echo ""
    echo "⚠️  Some tests failed. Review test output:"
    echo "Run 'cd frontend && npm test' to see details."
    echo ""
    echo "Tip: Use 'git push --no-verify' to skip if tests are expected to fail."
    exit 1
  fi

  # Run E2E tests with a 3-minute hard limit.
  # On feature branches: only run specs relevant to changed files (fast path).
  # On main: run the full suite. CI always finishes the full run.
  lsof -i :4173 -t 2>/dev/null | xargs kill -9 2>/dev/null || true

  # Determine which E2E specs to run based on changed files vs main
  changed_files=$(git diff --name-only origin/main...HEAD 2>/dev/null || git diff --name-only HEAD~1 2>/dev/null)
  e2e_specs=""

  if echo "$changed_files" | grep -qE "wasm/|dtos\.rs|parser\.rs|layout/"; then
    e2e_specs="e2e/play-score-plugin.spec.ts e2e/demo-flow.spec.ts"
  fi
  if echo "$changed_files" | grep -qE "metronome|tempo|BPM"; then
    e2e_specs="$e2e_specs e2e/metronome.spec.ts"
  fi
  if echo "$changed_files" | grep -qE "persist|storage|IndexedDB|local-storage"; then
    e2e_specs="$e2e_specs e2e/persist-uploaded-scores.spec.ts"
  fi
  if echo "$changed_files" | grep -qE "train|practice|complexity"; then
    e2e_specs="$e2e_specs e2e/train-view.spec.ts e2e/train-from-score.spec.ts e2e/train-complexity-levels.spec.ts"
  fi

  # Deduplicate and trim
  e2e_specs=$(echo "$e2e_specs" | tr ' ' '\n' | sort -u | tr '\n' ' ' | xargs)

  if [ -n "$e2e_specs" ]; then
    echo "  - Running E2E tests (impacted specs, 3 min limit): $e2e_specs"
    e2e_cmd="npx playwright test --config playwright.config.prod.ts --reporter=list $e2e_specs"
  else
    echo "  - Running E2E tests (full suite, 3 min limit)..."
    e2e_cmd="npx playwright test --config playwright.config.prod.ts --reporter=list"
  fi

  # Background process + manual wait loop (portable; 'timeout' is not on macOS)
  $e2e_cmd > /tmp/e2e-prepush.log 2>&1 &
  playwright_pid=$!
  e2e_exit=0
  waited=0
  while kill -0 "$playwright_pid" 2>/dev/null; do
    if [ "$waited" -ge 180 ]; then
      kill "$playwright_pid" 2>/dev/null
      wait "$playwright_pid" 2>/dev/null
      e2e_exit=124
      break
    fi
    sleep 1
    waited=$((waited + 1))
  done
  if [ "$e2e_exit" -ne 124 ]; then
    wait "$playwright_pid"
    e2e_exit=$?
  fi

  e2e_passed=$(grep -c ' ✓ ' /tmp/e2e-prepush.log 2>/dev/null | tr -d '[:space:]' || echo 0)
  e2e_failed=$(grep -cE '^\s+[0-9]+\) \[' /tmp/e2e-prepush.log 2>/dev/null | tr -d '[:space:]' || echo 0)
  e2e_passed=${e2e_passed:-0}
  e2e_failed=${e2e_failed:-0}

  if [ "$e2e_exit" -eq 124 ]; then
    # Killed by the 3-min timeout
    if [ "$e2e_failed" -gt 0 ]; then
      echo ""
      echo "❌ E2E timed out with $e2e_failed failure(s) already detected ($e2e_passed passed):"
      tail -50 /tmp/e2e-prepush.log
      echo ""
      echo "Run 'cd frontend && npm run e2e' to reproduce locally."
      exit 1
    else
      echo "  ⏱  E2E hit 3-min limit — $e2e_passed passed, 0 failures. CI will finish the run."
    fi
  elif [ "$e2e_exit" -ne 0 ]; then
    echo ""
    echo "❌ E2E tests failed ($e2e_passed passed, $e2e_failed failed):"
    tail -50 /tmp/e2e-prepush.log
    echo ""
    echo "Run 'cd frontend && npm run e2e' to reproduce locally."
    exit 1
  else
    echo "  E2E: $e2e_passed tests passed"
  fi

  cd ..
  
  echo "✅ Build and tests passed"
else
  echo "ℹ️  Skipping validation for branch: $current_branch"
fi

echo "✅ Pre-push validation passed"
exit 0
